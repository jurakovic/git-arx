#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# git-arx – Branch Archive Tool for Git
# Archive local git branches that have no remote tracking branch.
# Usage: git arx <command> [options]
# =============================================================================

# --- CONFIG HELPERS ----------------------------------------------------------

_arx_require_git() {
    if ! git rev-parse --git-dir > /dev/null 2>&1; then
        printf 'git-arx: not inside a git repository\n' >&2
        exit 1
    fi
}

_arx_git_root() {
    git rev-parse --show-toplevel
}

_arx_config_storerefs() {
    git config --get arx.storerefs 2>/dev/null || printf 'true'
}

_arx_config_storefile() {
    git config --get arx.storefile 2>/dev/null || printf 'false'
}

_arx_config_file() {
    local filename
    filename=$(git config --get arx.filepath 2>/dev/null || printf '.gitarchive')
    # Resolve relative to repo root, not $PWD
    printf '%s/%s' "$ARX_GIT_ROOT" "$filename"
}

_arx_config_refsprefix() {
    git config --get arx.refsprefix 2>/dev/null || printf 'refs/arx/'
}

_arx_require_storage() {
    local required="$1"
    local use_refs use_file
    use_refs=$(_arx_config_storerefs)
    use_file=$(_arx_config_storefile)
    case "$required" in
        refs)
            [[ "$use_refs" == "true" ]] && return 0
            printf 'git-arx: this command requires refs storage (set: git config arx.storerefs true)\n' >&2
            exit 1
            ;;
        file)
            [[ "$use_file" == "true" ]] && return 0
            printf 'git-arx: this command requires file storage (set: git config arx.storefile true)\n' >&2
            exit 1
            ;;
        both)
            [[ "$use_refs" == "true" && "$use_file" == "true" ]] && return 0
            printf 'git-arx: this command requires both storage backends (arx.storerefs and arx.storefile must both be true)\n' >&2
            exit 1
            ;;
    esac
}

# --- BACKEND: FILE -----------------------------------------------------------

_arx_file_read() {
    local archive
    archive=$(_arx_config_file)
    [[ -f "$archive" ]] || return 0
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Skip blank lines and comment lines
        [[ -z "$line" || "$line" == \#* ]] && continue
        printf '%s\n' "$line"
    done < "$archive"
}

_arx_file_write() {
    local branch="$1" sha="$2" date="$3"
    local archive tmpfile
    archive=$(_arx_config_file)
    tmpfile="${archive}.tmp.$$"

    # Start fresh temp file; preserve header comment if archive exists
    if [[ -f "$archive" ]]; then
        # Copy header comments, filter out existing entry for this branch
        while IFS= read -r line || [[ -n "$line" ]]; do
            if [[ "$line" == \#* || -z "$line" ]]; then
                printf '%s\n' "$line" >> "$tmpfile"
            elif [[ "${line%% *}" != "$branch" ]]; then
                printf '%s\n' "$line" >> "$tmpfile"
            fi
        done < "$archive"
    else
        printf '# git-arx archive – do not edit manually\n' > "$tmpfile"
    fi

    printf '%s %s %s\n' "$branch" "$sha" "$date" >> "$tmpfile"

    # MINGW64-safe atomic replace
    [[ -f "$archive" ]] && rm -f "$archive"
    mv "$tmpfile" "$archive"
}

_arx_file_delete() {
    local branch="$1"
    local archive tmpfile
    archive=$(_arx_config_file)
    [[ -f "$archive" ]] || return 0
    tmpfile="${archive}.tmp.$$"

    while IFS= read -r line || [[ -n "$line" ]]; do
        [[ -n "$line" && "$line" != \#* && "${line%% *}" == "$branch" ]] && continue
        printf '%s\n' "$line" >> "$tmpfile"
    done < "$archive"

    rm -f "$archive"
    mv "$tmpfile" "$archive"
}

# --- BACKEND: REFS -----------------------------------------------------------

_arx_refs_read() {
    local refsprefix
    refsprefix=$(_arx_config_refsprefix)
    git for-each-ref \
        --format='%(refname) %(objectname) %(creatordate:iso-strict)' \
        "$refsprefix" \
    | while IFS=' ' read -r refname sha date rest; do
        local branch="${refname#$refsprefix}"
        printf '%s %s %s\n' "$branch" "$sha" "$date"
    done
}

_arx_refs_write() {
    local branch="$1" sha="$2"
    local refsprefix
    refsprefix=$(_arx_config_refsprefix)
    git update-ref "${refsprefix}${branch}" "$sha"
}

_arx_refs_delete() {
    local branch="$1"
    local refsprefix
    refsprefix=$(_arx_config_refsprefix)
    git update-ref -d "${refsprefix}${branch}" 2>/dev/null || true
}

# --- ABSTRACTION LAYER -------------------------------------------------------

_arx_read_all() {
    local use_refs use_file
    use_refs=$(_arx_config_storerefs)
    use_file=$(_arx_config_storefile)
    if [[ "$use_refs" == "true" && "$use_file" == "true" ]]; then
        # Union merge: refs are primary; supplement with file-only entries
        declare -A seen
        while IFS=' ' read -r branch sha date rest; do
            seen["$branch"]=1
            printf '%s %s %s\n' "$branch" "$sha" "$date"
        done < <(_arx_refs_read)
        while IFS=' ' read -r branch sha date rest; do
            if [[ -z "${seen[$branch]+x}" ]]; then
                printf '%s %s %s\n' "$branch" "$sha" "$date"
            fi
        done < <(_arx_file_read)
    elif [[ "$use_refs" == "true" ]]; then
        _arx_refs_read
    elif [[ "$use_file" == "true" ]]; then
        _arx_file_read
    else
        printf 'git-arx: no storage backend enabled (set arx.storerefs=true or arx.storefile=true)\n' >&2
        exit 1
    fi
}

_arx_write() {
    local branch="$1" sha="$2" date="$3"
    local use_refs use_file
    use_refs=$(_arx_config_storerefs)
    use_file=$(_arx_config_storefile)
    if [[ "$use_file" == "true" ]]; then
        _arx_file_write "$branch" "$sha" "$date"
    fi
    if [[ "$use_refs" == "true" ]]; then
        _arx_refs_write "$branch" "$sha"
    fi
}

_arx_delete() {
    local branch="$1"
    local use_refs use_file
    use_refs=$(_arx_config_storerefs)
    use_file=$(_arx_config_storefile)
    if [[ "$use_file" == "true" ]]; then
        _arx_file_delete "$branch"
    fi
    if [[ "$use_refs" == "true" ]]; then
        _arx_refs_delete "$branch"
    fi
}

_arx_lookup_branch() {
    local branch="$1"
    _arx_read_all | while IFS=' ' read -r b sha date rest; do
        if [[ "$b" == "$branch" ]]; then
            printf '%s %s\n' "$sha" "$date"
        fi
    done
}

_arx_sha_exists() {
    local sha="$1"
    git cat-file -e "$sha" 2>/dev/null
}

_arx_lookup_sha() {
    local target_sha="$1" match_name sha date rest
    local -a names=()
    while IFS=' ' read -r match_name sha date rest; do
        [[ "$sha" == "$target_sha" ]] && names+=("$match_name") || true
    done < <(_arx_read_all)
    [[ ${#names[@]} -gt 0 ]] && printf '%s' "${names[*]}" || true
}

# --- COMMANDS ----------------------------------------------------------------

cmd_add() {
    local branch="" archive_name="" force=0
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force|-f) force=1 ;;
            --*) printf 'git-arx: unknown option "%s"\n' "$1" >&2; exit 1 ;;
            *)
                if [[ -z "$branch" ]]; then branch="$1"
                elif [[ -z "$archive_name" ]]; then archive_name="$1"
                else printf 'git-arx: unexpected argument "%s"\n' "$1" >&2; exit 1
                fi ;;
        esac
        shift
    done

    [[ -z "$branch" ]] && { printf 'Usage: git arx add <branch> [archive-name] [--force]\n' >&2; exit 1; }

    if ! git rev-parse --verify "refs/heads/${branch}" > /dev/null 2>&1; then
        printf 'git-arx: branch "%s" not found in local branches\n' "$branch" >&2
        exit 1
    fi

    local sha date
    sha=$(git rev-parse "refs/heads/${branch}")
    date=$(git log -1 --format=%aI "refs/heads/${branch}")

    local store_name="${archive_name:-$branch}"

    local existing_entry existing_sha
    existing_entry=$(_arx_lookup_branch "$store_name")
    if [[ -n "$existing_entry" ]]; then
        existing_sha=$(printf '%s' "$existing_entry" | awk '{print $1}')
        if [[ "$existing_sha" == "$sha" ]]; then
            printf 'Already archived: %s at %s\n' "$store_name" "${sha:0:8}"
            return 0
        fi
        if [[ $force -eq 0 ]]; then
            printf 'git-arx: conflict: "%s" is already archived at %s (current: %s)\n' \
                "$store_name" "${existing_sha:0:8}" "${sha:0:8}" >&2
            printf 'To overwrite:                  git arx add %s --force\n' "$branch" >&2
            if [[ -z "$archive_name" ]]; then
                printf 'To archive under a new name:   git arx add %s <archive-name>\n' "$branch" >&2
            fi
            exit 1
        fi
    fi

    local existing_as
    existing_as=$(_arx_lookup_sha "$sha")
    if [[ -n "$existing_as" ]]; then
        printf 'Note: %s is already archived as "%s"\n' "${sha:0:8}" "$existing_as"
    fi

    _arx_write "$store_name" "$sha" "$date"
    if [[ -n "$archive_name" ]]; then
        printf 'Archived: %s (as %s) at %s\n' "$branch" "$store_name" "${sha:0:8}"
    else
        printf 'Archived: %s at %s\n' "$store_name" "${sha:0:8}"
    fi
}

cmd_remove() {
    local branch="${1:-}"
    [[ -z "$branch" ]] && { printf 'Usage: git arx remove <branch>\n' >&2; exit 1; }

    local entry
    entry=$(_arx_lookup_branch "$branch")
    if [[ -z "$entry" ]]; then
        printf 'git-arx: branch "%s" not found in archive\n' "$branch" >&2
        exit 1
    fi

    _arx_delete "$branch"
    printf 'Removed: %s\n' "$branch"
}

cmd_rename() {
    local old_name="${1:-}" new_name="${2:-}"
    if [[ -z "$old_name" || -z "$new_name" ]]; then
        printf 'Usage: git arx rename <old-name> <new-name>\n' >&2; exit 1
    fi
    if [[ "$old_name" == "$new_name" ]]; then
        printf 'git-arx: old and new names are identical\n' >&2; exit 1
    fi

    local entry
    entry=$(_arx_lookup_branch "$old_name")
    if [[ -z "$entry" ]]; then
        printf 'git-arx: branch "%s" not found in archive\n' "$old_name" >&2
        exit 1
    fi

    local existing
    existing=$(_arx_lookup_branch "$new_name")
    if [[ -n "$existing" ]]; then
        printf 'git-arx: "%s" already exists in archive\n' "$new_name" >&2
        exit 1
    fi

    local sha date
    sha=$(printf '%s' "$entry" | awk '{print $1}')
    date=$(printf '%s' "$entry" | awk '{print $2}')

    _arx_write "$new_name" "$sha" "$date"
    _arx_delete "$old_name"
    printf 'Renamed: %s -> %s\n' "$old_name" "$new_name"
}

cmd_update() {
    local dry_run=0 force=0
    for arg in "$@"; do
        case "$arg" in
            --dry-run|-n) dry_run=1 ;;
            --force|-f)   force=1 ;;
            *) printf 'git-arx: unknown option "%s"\n' "$arg" >&2; exit 1 ;;
        esac
    done

    # Load archive once into associative arrays for O(1) lookup.
    # %(upstream) last – see INTERNALS for the IFS tab-collapsing explanation.
    declare -A arc_by_name arc_by_sha
    while IFS=' ' read -r b sha date rest; do
        arc_by_name["$b"]="$sha"
        [[ -z "${arc_by_sha[$sha]:-}" ]] && arc_by_sha["$sha"]="$b" || true
    done < <(_arx_read_all)

    local archived=0 conflicts=0 already_safe=0
    while IFS=$'\t' read -r branch sha date upstream_ref; do
        # Skip if upstream ref exists locally (live remote tracking branch)
        if [[ -n "$upstream_ref" ]] && git rev-parse --verify "$upstream_ref" > /dev/null 2>&1; then
            continue
        fi

        local existing_sha existing_as
        existing_sha="${arc_by_name[$branch]:-}"
        if [[ -n "$existing_sha" ]]; then
            if [[ "$existing_sha" == "$sha" ]]; then
                continue  # already up to date
            fi
            if [[ $force -eq 0 ]]; then
                existing_as="${arc_by_sha[$sha]:-}"
                if [[ -n "$existing_as" ]]; then
                    printf 'Already safe: %s (%s archived as "%s") – skipped\n' "$branch" "${sha:0:8}" "$existing_as"
                    already_safe=$(( already_safe + 1 ))
                else
                    printf 'Conflict: %s (archived: %s, current: %s) – skipped\n' \
                        "$branch" "${existing_sha:0:8}" "${sha:0:8}"
                    conflicts=$(( conflicts + 1 ))
                fi
                continue
            fi
            [[ $dry_run -eq 0 ]] && _arx_write "$branch" "$sha" "$date"
            arc_by_name[$branch]="$sha"
            arc_by_sha[$sha]="$branch"
            printf 'Updated: %s at %s\n' "$branch" "${sha:0:8}"
            archived=$(( archived + 1 ))
            continue
        fi

        existing_as="${arc_by_sha[$sha]:-}"
        if [[ -n "$existing_as" ]]; then
            printf 'Already safe: %s (%s archived as "%s") – skipped\n' "$branch" "${sha:0:8}" "$existing_as"
            already_safe=$(( already_safe + 1 ))
            continue
        fi

        [[ $dry_run -eq 0 ]] && _arx_write "$branch" "$sha" "$date"
        arc_by_name[$branch]="$sha"
        arc_by_sha[$sha]="$branch"
        printf 'Archived: %s\n' "$branch"
        archived=$(( archived + 1 ))
    done < <(git for-each-ref \
        --format='%(refname:short)%09%(objectname)%09%(authordate:iso-strict)%09%(upstream)' \
        refs/heads/)

    printf 'Done. Archived %d branch(es)' "$archived"
    [[ $already_safe -gt 0 ]] && printf ', %d already safe (SHA archived under different name)' "$already_safe" || true
    [[ $conflicts -gt 0 ]] && printf ', %d conflict(s) skipped' "$conflicts" || true
    printf '.\n'
    [[ $dry_run -eq 1 ]] && printf '(dry run – no changes written)\n' || true
    [[ $conflicts -gt 0 ]] && exit 1 || true
}

cmd_status() {
    local sort_by="name" order="asc"
    for arg in "$@"; do
        case "$arg" in
            --sort=name)  sort_by="name" ;;
            --sort=date)  sort_by="date" ;;
            --order=asc)  order="asc" ;;
            --order=desc) order="desc" ;;
            *) printf 'git-arx: unknown option "%s"\n' "$arg" >&2; exit 1 ;;
        esac
    done

    # Load entire archive once into associative arrays for O(1) lookup,
    # avoiding repeated _arx_read_all calls inside the branch loop.
    declare -A arc_by_name arc_by_sha
    while IFS=' ' read -r b sha date rest; do
        arc_by_name["$b"]="$sha"
        [[ -z "${arc_by_sha[$sha]:-}" ]] && arc_by_sha["$sha"]="$b" || true
    done < <(_arx_read_all)

    local -a rows=()
    # Single for-each-ref call fetches SHA, date, author, and upstream for
    # all branches at once – replaces per-branch git rev-parse + git log calls.
    # NOTE: %(upstream) must be LAST. Tab is IFS whitespace, so consecutive
    # tabs collapse – a mid-format empty %(upstream) would shift all following
    # fields left. Placing it last lets bash strip the trailing tab cleanly.
    while IFS=$'\t' read -r branch sha date author upstream_ref; do
        if [[ -n "$upstream_ref" ]] && git rev-parse --verify "$upstream_ref" > /dev/null 2>&1; then
            continue
        fi

        local status existing_sha existing_as
        existing_sha="${arc_by_name[$branch]:-}"

        if [[ "$existing_sha" == "$sha" ]]; then
            status="Archived"
        else
            existing_as="${arc_by_sha[$sha]:-}"
            if [[ -n "$existing_as" ]]; then
                status="Archived as \"${existing_as}\""
            elif [[ -n "$existing_sha" ]]; then
                status="Conflict (archived: ${existing_sha:0:8})"
            else
                status="Not archived"
            fi
        fi

        rows+=("$(printf '%s\t%s\t%s\t%s\t%s' "$branch" "${sha:0:8}" "${date:0:10}" "$author" "$status")")
    done < <(git for-each-ref \
        --format='%(refname:short)%09%(objectname)%09%(authordate:iso-strict)%09%(authorname)%09%(upstream)' \
        refs/heads/)

    if [[ ${#rows[@]} -eq 0 ]]; then
        printf 'No local branches without a remote upstream.\n'
        return 0
    fi

    local sort_field sort_flag
    [[ "$sort_by" == "name" ]] && sort_field=1 || sort_field=3
    [[ "$order" == "asc" ]] && sort_flag="" || sort_flag="-r"

    printf '%-40s %-9s %-12s %-20s %s\n' "BRANCH" "SHA" "DATE" "AUTHOR" "STATUS"
    printf '%-40s %-9s %-12s %-20s %s\n' "------" "---" "----" "------" "------"
    local b s d a st aw saved_lc ac bc
    # shellcheck disable=SC2086
    while IFS=$'\t' read -r b s d a st; do
        # %-20s pads by bytes; correct for multibyte chars in author names.
        ac=${#a}; saved_lc="${LC_ALL:-}"; LC_ALL=C; bc=${#a}; LC_ALL="$saved_lc"
        aw=$(( 20 + bc - ac ))
        printf "%-40s %-9s %-12s %-${aw}s %s\n" "$b" "$s" "$d" "$a" "$st"
    done < <(printf '%s\n' "${rows[@]}" | sort $sort_flag -t$'\t' -k"${sort_field}")
}

cmd_list() {
    local sort_by="date" order="desc" list_storage="" show_author=0

    for arg in "$@"; do
        case "$arg" in
            --sort=name)  sort_by="name" ;;
            --sort=date)  sort_by="date" ;;
            --order=asc)  order="asc" ;;
            --order=desc) order="desc" ;;
            --author)     show_author=1 ;;
            --storage=file|--storage=refs)
                list_storage="${arg#--storage=}" ;;
            --storage=*)
                printf 'git-arx: invalid --storage value "%s" (use: file, refs)\n' "${arg#--storage=}" >&2
                exit 1 ;;
            *) printf 'git-arx: unknown option "%s"\n' "$arg" >&2; exit 1 ;;
        esac
    done

    # Validate that the requested backend is available in the current storage config
    if [[ -n "$list_storage" ]]; then
        _arx_require_storage "$list_storage"
    fi

    local entries
    case "$list_storage" in
        file) entries=$(_arx_file_read) ;;
        refs) entries=$(_arx_refs_read) ;;
        *)    entries=$(_arx_read_all) ;;
    esac

    if [[ -z "$entries" ]]; then
        printf 'No archived branches.\n'
        return 0
    fi

    # Sort: field 1 = branch name, field 3 = date (ISO-8601 sorts lexicographically)
    local sort_field sort_flag
    [[ "$sort_by" == "name" ]] && sort_field=1 || sort_field=3
    [[ "$order" == "asc" ]] && sort_flag="" || sort_flag="-r"

    # shellcheck disable=SC2086
    local sorted
    sorted=$(printf '%s\n' "$entries" | sort $sort_flag -k"${sort_field}")

    # For --author, fetch all authors in one git log call instead of per-entry.
    declare -A author_by_sha
    if [[ $show_author -eq 1 ]]; then
        local -a all_shas=()
        while IFS=' ' read -r _b sha _rest; do
            all_shas+=("$sha")
        done <<< "$sorted"
        if [[ ${#all_shas[@]} -gt 0 ]]; then
            while IFS=' ' read -r sha author_name; do
                author_by_sha["$sha"]="$author_name"
            done < <(git log --no-walk --format='%H %an' "${all_shas[@]}" 2>/dev/null || true)
        fi
    fi

    # Print header and table
    if [[ $show_author -eq 1 ]]; then
        printf '%-40s %-9s %-12s %s\n' "BRANCH" "SHA" "DATE" "AUTHOR"
        printf '%-40s %-9s %-12s %s\n' "------" "---" "----" "------"
    else
        printf '%-40s %-9s %s\n' "BRANCH" "SHA" "DATE"
        printf '%-40s %-9s %s\n' "------" "---" "----"
    fi
    while IFS=' ' read -r branch sha date rest; do
        if [[ $show_author -eq 1 ]]; then
            printf '%-40s %-9s %-12s %s\n' "$branch" "${sha:0:8}" "${date:0:10}" "${author_by_sha[$sha]:-\(gc\)}"
        else
            printf '%-40s %-9s %s\n' "$branch" "${sha:0:8}" "${date:0:10}"
        fi
    done <<< "$sorted"
}

cmd_log() {
    local branch="${1:-}"
    [[ -z "$branch" ]] && { printf 'Usage: git arx log <branch> [git-log-options...]\n' >&2; exit 1; }
    shift  # remove branch name; remaining "$@" are git log flags

    local entry
    entry=$(_arx_lookup_branch "$branch")
    if [[ -z "$entry" ]]; then
        printf 'git-arx: branch "%s" not found in archive\n' "$branch" >&2
        exit 1
    fi

    local sha
    sha=$(printf '%s' "$entry" | awk '{print $1}')

    if ! _arx_sha_exists "$sha"; then
        printf 'git-arx: WARNING: SHA %s for branch "%s" appears to have been garbage collected.\n' "${sha:0:8}" "$branch" >&2
        printf 'The commit history is no longer available. You can remove it with: git arx remove %s\n' "$branch" >&2
        exit 1
    fi

    git log "$sha" "$@"
}

cmd_checkout() {
    local branch="${1:-}"
    [[ -z "$branch" ]] && { printf 'Usage: git arx checkout <branch>\n' >&2; exit 1; }

    local entry
    entry=$(_arx_lookup_branch "$branch")
    if [[ -z "$entry" ]]; then
        printf 'git-arx: branch "%s" not found in archive\n' "$branch" >&2
        exit 1
    fi

    local sha
    sha=$(printf '%s' "$entry" | awk '{print $1}')

    if ! _arx_sha_exists "$sha"; then
        printf 'git-arx: WARNING: SHA %s for branch "%s" appears to have been garbage collected.\n' "${sha:0:8}" "$branch" >&2
        printf 'The branch cannot be restored. You can remove it with: git arx remove %s\n' "$branch" >&2
        exit 1
    fi

    if git rev-parse --verify "refs/heads/${branch}" > /dev/null 2>&1; then
        printf 'git-arx: a local branch named "%s" already exists\n' "$branch" >&2
        exit 1
    fi

    git checkout -b "$branch" "$sha"
    printf 'Restored branch: %s at %s\n' "$branch" "${sha:0:8}"
}

cmd_merge() {
    _arx_require_storage file

    local file1="" file2="" output=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o) shift; output="${1:-}" ;;
            *)
                if [[ -z "$file1" ]]; then file1="$1"
                elif [[ -z "$file2" ]]; then file2="$1"
                else printf 'git-arx: unexpected argument "%s"\n' "$1" >&2; exit 1
                fi
                ;;
        esac
        shift
    done

    [[ -z "$file1" || -z "$file2" || -z "$output" ]] && {
        printf 'Usage: git arx merge <file1> <file2> -o <output>\n' >&2; exit 1
    }
    [[ -f "$file1" ]] || { printf 'git-arx: file not found: %s\n' "$file1" >&2; exit 1; }
    [[ -f "$file2" ]] || { printf 'git-arx: file not found: %s\n' "$file2" >&2; exit 1; }

    declare -A map1 map2
    local line branch sha date

    while IFS=' ' read -r branch sha date rest; do
        [[ -z "$branch" || "$branch" == \#* ]] && continue
        map1["$branch"]="$sha $date"
    done < "$file1"

    while IFS=' ' read -r branch sha date rest; do
        [[ -z "$branch" || "$branch" == \#* ]] && continue
        map2["$branch"]="$sha $date"
    done < "$file2"

    local merged=0 conflicts=0
    local tmpfile="${output}.tmp.$$"
    printf '# git-arx archive – merged from %s and %s\n' "$file1" "$file2" > "$tmpfile"

    # Collect all branch names
    declare -A all_branches
    for b in "${!map1[@]}" "${!map2[@]}"; do all_branches["$b"]=1; done

    for b in "${!all_branches[@]}"; do
        local v1="${map1[$b]+${map1[$b]}}"
        local v2="${map2[$b]+${map2[$b]}}"
        if [[ -n "$v1" && -n "$v2" ]]; then
            local s1="${v1%% *}" s2="${v2%% *}"
            if [[ "$s1" == "$s2" ]]; then
                printf '%s %s\n' "$b" "$v1" >> "$tmpfile"
                merged=$(( merged + 1 ))
            else
                printf 'CONFLICT: %s has different SHAs (%s vs %s) – skipped\n' "$b" "${s1:0:8}" "${s2:0:8}" >&2
                conflicts=$(( conflicts + 1 ))
            fi
        elif [[ -n "$v1" ]]; then
            printf '%s %s\n' "$b" "$v1" >> "$tmpfile"
            merged=$(( merged + 1 ))
        else
            printf '%s %s\n' "$b" "$v2" >> "$tmpfile"
            merged=$(( merged + 1 ))
        fi
    done

    [[ -f "$output" ]] && rm -f "$output"
    mv "$tmpfile" "$output"
    printf 'Merged %d entries to %s' "$merged" "$output"
    [[ $conflicts -gt 0 ]] && printf ' (%d conflict(s) skipped)' "$conflicts"
    printf '\n'
}

cmd_sync() {
    _arx_require_storage both

    local dry_run=0 force=""
    for arg in "$@"; do
        case "$arg" in
            --dry-run|-n)  dry_run=1 ;;
            --force-file)  force="file" ;;
            --force-refs)  force="refs" ;;
            *) printf 'git-arx: unknown sync option "%s"\n' "$arg" >&2; exit 1 ;;
        esac
    done

    declare -A refs_map file_map
    local branch sha date

    while IFS=' ' read -r branch sha date rest; do
        refs_map["$branch"]="$sha $date"
    done < <(_arx_refs_read)

    while IFS=' ' read -r branch sha date rest; do
        file_map["$branch"]="$sha $date"
    done < <(_arx_file_read)

    declare -A all_branches
    for b in "${!refs_map[@]}" "${!file_map[@]}"; do all_branches["$b"]=1; done

    local had_conflict=0

    for b in "${!all_branches[@]}"; do
        local rv="${refs_map[$b]+${refs_map[$b]}}"
        local fv="${file_map[$b]+${file_map[$b]}}"

        if [[ -n "$rv" && -n "$fv" ]]; then
            local rs="${rv%% *}" fs="${fv%% *}"
            if [[ "$rs" == "$fs" ]]; then
                : # in sync
            else
                if [[ -n "$force" ]]; then
                    if [[ "$force" == "file" ]]; then
                        local fsha="${fv%% *}" fdate="${fv#* }"
                        [[ $dry_run -eq 0 ]] && _arx_refs_write "$b" "$fsha"
                        printf 'Resolved (force-file): %s -> refs=%s\n' "$b" "${fsha:0:8}"
                    else
                        local rsha="${rv%% *}" rdate="${rv#* }"
                        [[ $dry_run -eq 0 ]] && _arx_file_write "$b" "$rsha" "$rdate"
                        printf 'Resolved (force-refs): %s -> file=%s\n' "$b" "${rsha:0:8}"
                    fi
                else
                    printf 'CONFLICT: %s – refs=%s file=%s. Use --force-refs or --force-file.\n' \
                        "$b" "${rs:0:8}" "${fs:0:8}" >&2
                    had_conflict=1
                fi
            fi
        elif [[ -n "$rv" ]]; then
            local rsha="${rv%% *}" rdate="${rv#* }"
            if [[ "$force" == "file" ]]; then
                # File is authoritative – entry absent from file means remove it from refs
                [[ $dry_run -eq 0 ]] && _arx_refs_delete "$b"
                printf 'Removed from refs (force-file): %s\n' "$b"
            else
                [[ $dry_run -eq 0 ]] && _arx_file_write "$b" "$rsha" "$rdate"
                printf 'Synced to file: %s\n' "$b"
            fi
        else
            local fsha="${fv%% *}" fdate="${fv#* }"
            if [[ "$force" == "refs" ]]; then
                # Refs is authoritative – entry absent from refs means remove it from file
                [[ $dry_run -eq 0 ]] && _arx_file_delete "$b"
                printf 'Removed from file (force-refs): %s\n' "$b"
            else
                [[ $dry_run -eq 0 ]] && _arx_refs_write "$b" "$fsha"
                printf 'Synced to refs: %s\n' "$b"
            fi
        fi
    done

    [[ $had_conflict -eq 1 ]] && exit 1
    printf 'Sync complete.\n'
    [[ $dry_run -eq 1 ]] && printf '(dry run – no changes written)\n' || true
}

cmd_prune() {
    local force=0 dry_run=0
    for arg in "$@"; do
        case "$arg" in
            --force|-f)   force=1 ;;
            --dry-run|-n) dry_run=1 ;;
            *) printf 'git-arx: unknown option "%s"\n' "$arg" >&2; exit 1 ;;
        esac
    done

    # Determine current branch so we can skip it
    local current_branch
    current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || true)

    # Collect archived branches that still exist locally
    local -a branches=()
    local -a skipped=()
    while IFS=' ' read -r branch sha date rest; do
        if ! git rev-parse --verify "refs/heads/${branch}" > /dev/null 2>&1; then
            continue  # already deleted locally
        fi
        if [[ "$branch" == "$current_branch" ]]; then
            skipped+=("$branch")
            continue
        fi
        branches+=("$branch")
    done < <(_arx_read_all)

    if [[ ${#branches[@]} -eq 0 && ${#skipped[@]} -eq 0 ]]; then
        printf 'No archived branches found in local branches.\n'
        return 0
    fi

    if [[ ${#branches[@]} -gt 0 ]]; then
        printf 'The following local branches will be permanently deleted:\n'
        for b in "${branches[@]}"; do
            printf '  %s\n' "$b"
        done
        printf '\n'
    fi

    if [[ ${#skipped[@]} -gt 0 ]]; then
        printf 'Skipped (currently checked out):\n'
        for b in "${skipped[@]}"; do
            printf '  %s\n' "$b"
        done
        printf '\n'
    fi

    if [[ ${#branches[@]} -eq 0 ]]; then
        printf 'Nothing to delete.\n'
        return 0
    fi

    if [[ $dry_run -eq 1 ]]; then
        printf 'Done. Deleted %d branch(es).\n' "${#branches[@]}"
        printf '(dry run – no changes written)\n'
        return 0
    fi

    if [[ $force -eq 0 ]]; then
        printf 'WARNING: This is a dangerous operation. Deleted branches cannot be\n'
        printf 'recovered from git – only from the git-arx archive.\n'
        printf 'Type "yes" to continue: '
        local answer
        read -r answer || true
        if [[ "$answer" != "yes" ]]; then
            printf 'Aborted.\n'
            exit 1
        fi
    fi

    local deleted=0
    for b in "${branches[@]}"; do
        git branch -D "$b"
        deleted=$(( deleted + 1 ))
    done
    printf 'Done. Deleted %d branch(es).\n' "$deleted"
}

cmd_push() {
    _arx_require_storage refs
    local dry_run="" refsprefix
    refsprefix=$(_arx_config_refsprefix)
    for arg in "$@"; do
        case "$arg" in
            --dry-run|-n) dry_run="--dry-run" ;;
            *) printf 'git-arx: unknown option "%s"\n' "$arg" >&2; exit 1 ;;
        esac
    done
    git push $dry_run origin "${refsprefix}*:${refsprefix}*"
    [[ -n "$dry_run" ]] && printf '(dry run – no changes written)\n' || true
}

cmd_pull() {
    _arx_require_storage refs
    local refsprefix
    refsprefix=$(_arx_config_refsprefix)
    git fetch origin "${refsprefix}*:${refsprefix}*"

    # If file backend is also enabled, sync fetched refs into .gitarchive
    local use_file
    use_file=$(_arx_config_storefile)
    if [[ "$use_file" == "true" ]]; then
        local branch sha date
        while IFS=' ' read -r branch sha date rest; do
            _arx_file_write "$branch" "$sha" "$date"
        done < <(_arx_refs_read)
        printf 'Synced fetched refs to .gitarchive\n'
    fi
}

cmd_help() {
    cat <<'EOF'
git-arx – Branch Archive Tool for Git

Archive local git branches that have no remote tracking branch, preserving
the branch name and HEAD SHA for later inspection or restoration.

USAGE
  git arx <command> [options]

COMMANDS
  add <branch> [archive-name] [--force]  Archive a single branch
  remove <branch>                        Remove a branch from the archive
  rename <old> <new>                     Rename an archived branch
  status [--sort=name|date]              Show branches that would be archived by update
         [--order=asc|desc]
  update [-f|--force] [-n|--dry-run]     Archive all local branches with no upstream
  list [--sort=name|date]                List archived branches
       [--order=asc|desc]
       [--storage=file|refs]
       [--author]
  log <branch> [git-log-flags]           Show commits (delegates to git log)
  checkout <branch>                      Restore a branch from the archive
  prune [-f|--force] [-n|--dry-run]      Delete local branches that are archived
  merge <f1> <f2> -o <out>               Merge two .gitarchive files       [file only]
  push [-n|--dry-run]                    Push archived refs to remote      [refs only]
  pull                                   Pull archived refs from remote    [refs only]
  sync [-n|--dry-run]                    Reconcile file and refs backends  [file+refs]
       [--force-file]
       [--force-refs]
  help                                   Show this help

STORAGE BACKENDS
  Configured via two independent flags:
    git config arx.storerefs true|false   (default: true)
    git config arx.storefile true|false   (default: false)

  refs   Git refs under refs/arx/<branch>. Protects commits from gc.
         Enabled by default – archived commits remain reachable,
         preventing data loss if git gc runs after branch deletion.
         Never pushed to remote unless you run: git arx push
  file   Plain text .gitarchive file. Portable and committable.
         Enable for human-readable archives or team sharing via the repo.
         Commits may be lost after git gc if refs is also disabled.

OTHER CONFIG
  arx.filepath      Path to archive file (default: .gitarchive)
  arx.refsprefix   Refs namespace prefix (default: refs/arx/)

EXAMPLES
  git arx add feature/my-feature
  git arx add feature/my-feature --force
  git arx add feature/my-feature feature/my-feature-old
  git arx rename feature/my-feature feature/my-feature-v1
  git arx update
  git arx update --force
  git arx list --sort=date --order=desc
  git arx log feature/my-feature --oneline -10
  git arx checkout feature/my-feature
  git arx sync --dry-run
  git arx push

EOF
}

# --- ENTRY POINT -------------------------------------------------------------

main() {
    _arx_require_git
    ARX_GIT_ROOT=$(_arx_git_root)

    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        add)      cmd_add "$@" ;;
        remove)   cmd_remove "$@" ;;
        rename)   cmd_rename "$@" ;;
        status)   cmd_status "$@" ;;
        update)   cmd_update "$@" ;;
        list)     cmd_list "$@" ;;
        log)      cmd_log "$@" ;;
        checkout) cmd_checkout "$@" ;;
        prune)    cmd_prune "$@" ;;
        merge)    cmd_merge "$@" ;;
        push)     cmd_push "$@" ;;
        pull)     cmd_pull "$@" ;;
        sync)     cmd_sync "$@" ;;
        help|--help|-h) cmd_help ;;
        "")       cmd_help; exit 1 ;;
        *)
            printf 'git-arx: unknown command "%s"\n' "$cmd" >&2
            printf 'Run "git arx help" for usage.\n' >&2
            exit 1
            ;;
    esac
}

main "$@"
